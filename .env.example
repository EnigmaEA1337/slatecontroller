# =============================================================================
# Slate Controller - Environment variables example
# Copy to .env and fill in your values. NEVER commit .env.
# =============================================================================

# ---- Slate 7 Pro ----
SLATE_URL=https://192.168.8.1
SLATE_USERNAME=root
SLATE_PASSWORD=changeme

# ---- Database ----
DB_URL=sqlite+aiosqlite:///./data/db/slate.db

# ---- Auth ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Initial admin (created on first run if no user exists)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ---- CORS ----
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---- SIEM (optional) ----
SPLUNK_HEC_URL=
SPLUNK_HEC_TOKEN=

# ---- Traefik ----
TRAEFIK_ACME_EMAIL=you@example.com
TRAEFIK_DOMAIN=slate.local
TRAEFIK_API_DOMAIN=slate-api.local

# ---- Frontend ----
# Leave VITE_API_URL empty in dev — the Vite proxy forwards /api to the
# backend, and the browser uses same-origin requests (works from localhost,
# LAN, Tailscale, Traefik domain — no CORS gymnastics needed).
# Only set this if you intentionally want a locally-served UI to hit a
# remote backend.
# VITE_API_URL=
#
# Dev-only: where the Vite dev server proxies /api to. The compose file
# wires this to the backend service container.
VITE_BACKEND_URL=http://localhost:8000
